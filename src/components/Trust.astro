---
import Eyebrow from "./Eyebrow.astro";
import { trust } from "~/content/copy";
---
<section class="section trust" id="trust" aria-labelledby="trust-title">
  <div class="container">
    <header class="trust__head reveal">
      <Eyebrow>{trust.eyebrow}</Eyebrow>
      <h2 id="trust-title">
        {trust.title}<em class="it">{trust.titleItalic}</em>
      </h2>
      <p class="lead">{trust.lead}</p>
    </header>

    <ul class="trust__grid card-grid">
      {trust.items.map((t, i) => (
        <li class="trust__card reveal" data-delay={i % 3}>
          <div class="trust__seal" aria-hidden="true">
            <span class="trust__num mono">0{i + 1}</span>
            <span class="trust__rule"></span>
          </div>
          <h3 class="trust__h">{t.label}</h3>
          <p>{t.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust__head { max-width: 56ch; margin-bottom: 3rem; }
  .trust__head .eyebrow { margin-bottom: 1rem; }
  .trust__head h2 { margin-bottom: 1.1rem; }

  .trust__card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem 1.6rem 1.5rem;
    position: relative;
  }
  .trust__seal {
    display: flex; align-items: center; gap: 0.6rem;
    margin-bottom: 1.2rem;
  }
  .trust__num { font-size: 0.78rem; color: var(--green); font-weight: 600; letter-spacing: 0.04em; }
  .trust__rule { flex: 1; height: 1px; background: var(--line-strong); }
  .trust__h { font-size: 1.15rem; margin-bottom: 0.45rem; }
  .trust__card p { color: var(--muted); font-size: 0.96rem; }
</style>
