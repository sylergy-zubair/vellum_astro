---
import Eyebrow from "./Eyebrow.astro";
import LeadForm from "./LeadForm.astro";
import { cta } from "~/content/copy";
---
<section class="section section--ink cta" id="lead" aria-labelledby="cta-title">
  <div class="container cta__inner">
    <div class="cta__copy reveal">
      <Eyebrow tone="ink">{cta.eyebrow}</Eyebrow>
      <h2 id="cta-title">
        {cta.title}<em class="it">{cta.titleItalic}</em>
      </h2>
      <p class="lead">{cta.lead}</p>
      <ul class="cta__bullets">
        {cta.bullets.map((b) => (
          <li>
            <span class="cta__check" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12 L10 18 L20 6" />
              </svg>
            </span>
            {b}
          </li>
        ))}
      </ul>
    </div>

    <div class="cta__form reveal" data-delay="1">
      <LeadForm />
    </div>
  </div>
</section>

<style>
  .cta { position: relative; overflow: hidden; }
  .cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(50% 60% at 0% 100%, var(--green-soft), transparent 60%),
      radial-gradient(40% 50% at 100% 0%, oklch(0.560 0.095 150 / 0.10), transparent 60%);
    pointer-events: none;
  }
  .cta__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(2rem, 1rem + 3vw, 5rem);
    align-items: start;
  }
  .cta__copy h2 { margin: 1rem 0 1rem; color: var(--paper-on-ink); }
  .cta__copy p { color: var(--muted-on-ink); }
  .cta__bullets { display: flex; flex-direction: column; gap: 0.55rem; margin-top: 1.5rem; color: var(--muted-on-ink); }
  .cta__bullets li { display: flex; gap: 0.6rem; align-items: center; }
  .cta__check {
    width: 22px; height: 22px;
    border-radius: 999px;
    background: var(--ok-soft);
    color: var(--ok);
    display: grid; place-items: center;
  }

  .cta__form {
    background: var(--paper);
    color: var(--ink);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 1rem + 1.5vw, 2.25rem);
    box-shadow: var(--shadow-lg);
    border: 1px solid oklch(0.965 0.01 120 / 0.10);
  }

  @media (max-width: 800px) {
    .cta__inner { grid-template-columns: 1fr; }
  }
</style>
