---
import "~/styles/fonts.css";
import "~/styles/global.css";

import Seo from "~/components/Seo.astro";
import Nav from "~/components/Nav.astro";
import Hero from "~/components/Hero.astro";
import Problem from "~/components/Problem.astro";
import Features from "~/components/Features.astro";
import Trust from "~/components/Trust.astro";
import Comparison from "~/components/Comparison.astro";
import SocialProof from "~/components/SocialProof.astro";
import Cta from "~/components/Cta.astro";
import Faq from "~/components/Faq.astro";
import Footer from "~/components/Footer.astro";

const description =
  "Vellum is the modern, cloud-native operating system for UK estate and lettings agencies. Unified contacts, properties, tenancies and client money, with AI that knows lettings.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <Seo
      title="Vellum | The modern ledger for UK estate and lettings agencies"
      description={description}
    />
    <script is:inline>
      /* Plausible: privacy-first analytics. Loads only if domain is set. */
      (function () {
        var d = document.currentScript && document.currentScript.getAttribute("data-domain");
        if (!d) return;
        var s = document.createElement("script");
        s.defer = true;
        s.src = "https://plausible.io/js/script.js";
        s.setAttribute("data-domain", d);
        document.head.appendChild(s);
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main id="main">
      <Hero />
      <Problem />
      <Features />
      <Trust />
      <Comparison />
      <SocialProof />
      <Cta />
      <Faq />
    </main>
    <Footer />

    <script>
      /* Scroll-reveal via IntersectionObserver. Respects prefers-reduced-motion
         via the global CSS rule that disables .reveal transform/opacity. */
      (() => {
        if (!("IntersectionObserver" in window)) {
          document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      })();

      /* Sticky nav scroll state */
      (() => {
        const nav = document.querySelector("[data-nav]");
        if (!nav) return;
        let raf = 0;
        const onScroll = () => {
          if (raf) return;
          raf = requestAnimationFrame(() => {
            nav.setAttribute("data-scrolled", window.scrollY > 8 ? "true" : "false");
            raf = 0;
          });
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
